{
  "name": "pairmarket",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.9.0"
  },
  "scripts": {
    "docs:lint": "markdownlint-cli2",
    "devstack:deploy": "scripts/devstack.sh deploy",
    "devstack:down": "scripts/devstack.sh down",
    "devstack:env": "scripts/devstack.sh env",
    "devstack:logs": "scripts/devstack.sh logs",
    "devstack:reset": "scripts/devstack.sh reset",
    "devstack:status": "scripts/devstack.sh status",
    "devstack:up": "scripts/devstack.sh up",
    "fmt": "prettier --write \"**/*.{json,jsonc,yml,yaml,ts,tsx}\"",
    "fmt:check": "prettier --check \"**/*.{json,jsonc,yml,yaml,ts,tsx}\"",
    "move:build": "sui move build --path contracts/pairmarket --build-env mainnet",
    "move:test": "sui move test --path contracts/pairmarket --build-env mainnet",
    "test:runtime": "node --experimental-strip-types packages/core/test/plaintext.runtime.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "pnpm fmt:check && pnpm typecheck && pnpm test:runtime && pnpm docs:lint && pnpm move:build && pnpm move:test"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.5",
    "typescript": "6.0.3"
  }
}
